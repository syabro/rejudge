{
  "name": "@rejudge/pi",
  "version": "0.1.0",
  "description": "Independent multi-model review for AI agents, with a Pi extension and CLI.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/max-prtsr/rejudge.git"
  },
  "homepage": "https://github.com/max-prtsr/rejudge#readme",
  "bugs": {
    "url": "https://github.com/max-prtsr/rejudge/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "ai-agents",
    "multi-model",
    "review"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "files": [
    "bin/rejudge.js",
    "dist/extension.js",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "rejudge": "bin/rejudge.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "test:unit": "PI_TEST_UNIT_ONLY=1 vitest run",
    "typecheck": "tsc --noEmit",
    "build:cli": "bun build src/cli.ts --target=node --packages=external --outfile bin/rejudge.js && chmod +x bin/rejudge.js",
    "build:ext": "bun build src/index.ts --target=node --outfile dist/extension.js --external @earendil-works/pi-coding-agent --external @earendil-works/pi-ai --external @earendil-works/pi-tui --external typebox",
    "build": "bun run build:cli && bun run build:ext",
    "prepare": "bun run build"
  },
  "pi": {
    "extensions": [
      "./dist/extension.js"
    ]
  },
  "dependencies": {
    "neverthrow": "^8.2.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "@earendil-works/pi-ai": "^0.80.2"
  }
}
