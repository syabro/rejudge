{
  "name": "@rejudge/pi",
  "private": true,
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.80.2",
    "@earendil-works/pi-ai": "^0.80.2",
    "@earendil-works/pi-coding-agent": "0.80.2",
    "neverthrow": "^8.2.0",
    "typebox": "^1.2.3"
  },
  "scripts": {
    "test": "vitest run",
    "test:unit": "PI_TEST_UNIT_ONLY=1 vitest run",
    "typecheck": "tsc --noEmit",
    "build:cli": "bun build src/cli.ts --target=node --packages=external --outfile bin/rejudge.js && chmod +x bin/rejudge.js",
    "build:ext": "bun build src/index.ts --target=node --outfile dist/extension.js --external @earendil-works/pi-coding-agent --external @earendil-works/pi-ai --external @earendil-works/pi-tui --external typebox",
    "build": "bun run build:cli && bun run build:ext",
    "prepare": "bun run build"
  },
  "pi": {
    "extensions": [
      "./dist/extension.js"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-tui": "^0.79.0"
  }
}
